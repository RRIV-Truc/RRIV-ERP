SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_anon_or_publishable_key

# Bắt buộc để chạy scripts/apply_supabase_schema.py
# Lấy từ: Supabase Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=your_database_password

# Hoặc dán full connection string (Session pooler, port 6543):
# DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

EMAIL_SENDER=
EMAIL_PASSWORD=

# OpenWeatherMap One Call 3.0 (app Thời tiết)
OPENWEATHER_API_KEY=

# Mapbox (app Dẫn đường)
MAPBOX_TOKEN=

# VoiceRSS TTS (app Dẫn đường)
VOICERSS_API_KEY=

# ResponsiveVoice TTS (app Dẫn đường)
RESPONSIVEVOICE_KEY=

# Firebase Storage — hot cache tài liệu phiên họp
FIREBASE_STORAGE_BUCKET=rriv-erp.firebasestorage.app

# URL công khai ERP (link/QR Phòng họp). Production Firebase Hosting:
PUBLIC_BASE_URL=https://rriv-erp.web.app

# Supabase Storage bucket: meeting-docs (private). Tạo trên Dashboard trước khi upload.
# Khuyến nghị dùng service role cho upload server-side:
# SUPABASE_SERVICE_KEY=your_service_role_key
MEETING_DOCS_BUCKET=meeting-docs
MEETING_DOCS_MAX_MB=50
# Chỉ dev: lưu file tạm ổ đĩa khi Supabase lỗi (KHÔNG bật trên Render)
# MEETING_DOCS_ALLOW_LOCAL=1

# Firebase Realtime DB — module Phòng họp
# CHỈ Service Account (server Python). KHÔNG Firebase Auth user / OAuth cá nhân.
# Tải key: Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_SERVICE_ACCOUNT_PATH=
# Hoặc dán toàn bộ JSON Service Account (type phải là "service_account"):
FIREBASE_SERVICE_ACCOUNT=
